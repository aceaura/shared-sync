# =============================================================================
# secret.env.example —— frp 口令/密钥示例。复制为 secret.env 并改成自己的随机值。
#
#   cp v2/frp/secret.env.example v2/frp/secret.env
#   # 生成随机值:
#   #   FRP_AUTH_TOKEN=$(openssl rand -hex 24)
#   #   FRP_STCP_SECRET=$(openssl rand -hex 24)
#   #   FRP_DASHBOARD_PWD=$(openssl rand -hex 12)
#
# secret.env 已被 .gitignore 忽略,绝不入库。deploy-frps.sh 与一键 e2e 脚本都读它。
# =============================================================================

# frpc(数据中心/客户端)接入 frps 的共享口令。
FRP_AUTH_TOKEN=change-me-frp-auth-token

# STCP 端到端密钥(visitor 与数据中心 frpc 必须同值;VPS frps 不持有它)。
FRP_STCP_SECRET=change-me-stcp-secret

# frps 本地 dashboard 口令(仅回环 127.0.0.1:7500,经 ssh 隧道查看)。
FRP_DASHBOARD_PWD=change-me-dashboard

# VPS 公网地址(frpc serverAddr)。
FRP_SERVER_ADDR=54.198.93.78
